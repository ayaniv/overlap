# Google Calendar scheduling (M4) is entirely client-side and gated on this OAuth Client
# ID. Without it, the Schedule panel shows a note instead of the meeting form.
#
# 1. Create an OAuth 2.0 Client ID (Web application) in the Google Cloud Console.
# 2. Add authorized JavaScript origins: http://localhost:5173 and https://overlap.vercel.app
# 3. Copy this file to .env.local and paste the client id below.
VITE_GOOGLE_CLIENT_ID=

# PostHog analytics. Without both of these set, PostHog is skipped (a console
# warning is logged) and no analytics events are sent.
VITE_POSTHOG_PROJECT_TOKEN=
VITE_POSTHOG_HOST=
